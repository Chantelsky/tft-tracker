// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  riotAccounts RiotAccount[]
}

model RiotAccount {
  id        String   @id @default(cuid())
  puuid     String   @unique
  gameName  String
  tagLine   String
  region String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  matches   Match[]
  lpSnapshots LpSnapshot[]
}

model Match {
  id            String      @id @default(cuid())
  matchId       String
  region        String
  placement     Int
  level         Int
  lastRound     Int
  gameDatetime  DateTime
  riotAccountId String
  riotAccount   RiotAccount @relation(fields: [riotAccountId], references: [id])
  createdAt     DateTime    @default(now())
  matchUnits MatchUnit[]
  matchTraits MatchTrait[]
}

model MatchUnit {
  id String @id @default(cuid())
  characterId String
  tier Int
  rarity Int
  matchId String
  match        Match    @relation(fields: [matchId], references: [id])
}

model MatchTrait {
  id String @id @default(cuid())
  name String
  numUnits Int
  tierCurrent Int
  tierTotal Int
  matchId String
  match        Match    @relation(fields: [matchId], references: [id])
}

model LpSnapshot {
  id            String      @id @default(cuid())
  tier          String
  rank          String
  leaguePoints  Int
  recordedAt    DateTime    @default(now())
  riotAccountId String
  riotAccount   RiotAccount @relation(fields: [riotAccountId], references: [id])
}